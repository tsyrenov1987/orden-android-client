<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SYSTEM_EXEMPTED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".TunnelApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Tunnel">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Tunnel">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- One-tap activation App Link. workers.dev works today; orden.club is pre-baked so
                 switching the bot to it later needs no APK rebuild (just serve assetlinks there). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="joinorden.com" android:pathPrefix="/activate" />
                <data android:scheme="https" android:host="orden.tsyrenov1987.workers.dev" android:pathPrefix="/activate" />
                <data android:scheme="https" android:host="orden.club" android:pathPrefix="/activate" />
            </intent-filter>
        </activity>

        <!-- VPN tunnel service. Wired to the sing-box core in M1. -->
        <service
            android:name=".vpn.TunnelVpnService"
            android:exported="false"
            android:foregroundServiceType="systemExempted"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Home-screen widget: glanceable state + one-tap connect. -->
        <receiver
            android:name=".widget.OrdenWidgetProvider"
            android:exported="false"
            android:label="Orden VPN">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="club.orden.WIDGET_TOGGLE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/orden_widget_info" />
        </receiver>

        <!-- Quick Settings tile: connect/disconnect from the notification shade. -->
        <service
            android:name=".widget.OrdenTileService"
            android:exported="true"
            android:icon="@drawable/orden_shield"
            android:label="Orden VPN"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>

</manifest>
